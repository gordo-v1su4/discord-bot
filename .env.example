# Pindeck Discord Bot – same vars as pindeck/services/discord-bot
# Load order: .env.local, .env (cwd), then ../../.env.local, ../.env.local, etc.

# Health check (optional; default 8080 for GET /health)
# HEALTH_PORT=8080

# Discord (required)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# or DISCORD_APPLICATION_ID (same value)
DISCORD_GUILD_ID=

# Image presets (optional – uses samples if missing)
# DISCORD_IMAGES_JSON=[{"id":"x","label":"X","url":"https://...","emoji":"🎉"}]

# Ingest to Pindeck
INGEST_API_KEY=
DISCORD_INGEST_EMOJIS=📌
PINDECK_USER_ID=

# Convex HTTP (Pindeck) — copy/adjust if your deployment differs
PINDECK_INGEST_URL=https://convex-site.serving.cloud
CONVEX_SITE_URL=https://convex-site.serving.cloud
VITE_CONVEX_SITE_URL=https://convex-site.serving.cloud
PINDECK_DISCORD_QUEUE_URL=https://convex-site.serving.cloud/discordQueue
PINDECK_DISCORD_MODERATION_URL=https://convex-site.serving.cloud/discordModerate

# Media gateway compatibility proxy. Storage is RustFS-only.
MEDIA_GATEWAY_TOKEN=
MEDIA_API_TOKEN=
RUSTFS_MEDIA_API_URL=https://media.v1su4.dev
MEDIA_GATEWAY_BUCKET=pindeck

# Pinterest ingest sidecar. Uses INGEST_API_KEY and PINDECK_USER_ID above.
# Export browser cookies to /docker/pinterest-ingest/secrets/pinterest-cookies.txt on Hostinger.
POLL_INTERVAL_MINUTES=0
PUBLIC_BASE_URL=http://127.0.0.1:8095
# Optional: set 1 after source setup if you want every successful poll to forward new items.
AUTO_SYNC_PINDECK=0
# Optional smoke-test cap, e.g. 1. Leave blank for full watched-source extraction.
GALLERY_DL_RANGE=
